PORT=3000

# MySQL connection string used by Drizzle and the server for persisted features.
# Example:
# DATABASE_URL=mysql://root:password@localhost:3306/africa_market_expansion
DATABASE_URL=

# App/session auth
JWT_SECRET=
OWNER_OPEN_ID=
OAUTH_SERVER_URL=

# Built-in server-side LLM fallback
OPENAI_API_KEY=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Frontend OAuth and API bridge config
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Trusted data scheduler interval in minutes
TRUSTED_DATA_REFRESH_MINUTES=60
